

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Java Coffee Export</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
  <script src="script (2).js" defer></script>
</head>
<body>

  <header class="hero">
    <nav class="navbar">
      <div class="logo">Java Coffee Export</div>
      <ul>
        <li><a href="#home">Home</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#products">Products</a></li>
        <li><a href="#gallery">Gallery</a></li>
        <li><a href="#market">Export</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </nav>

    <div class="hero-content" id="home">
      <h1>Premium Indonesian Coffee Export</h1>
      <p>From Local Farmers to Global Markets by Ahmad Irfan Maulana</p>
      <div class="hero-btn">
        <a href="#products" class="btn">Explore Products</a>
        <a href="#contact" class="btn secondary">Contact Us</a>
      </div>
    </div>
  </header>

  <section class="about" id="about">
    <div class="about-image">
      <img src="pp1.jpg" alt="Coffee Farmer">
    </div>
    <div class="about-text">
      <h2>About Our Company</h2>
      <p>We work directly with local Indonesian farmers to provide premium coffee beans for international buyers.</p>
      <p>Our company focuses on quality, sustainability, and long-term partnerships with coffee importers around the world.</p>
    </div>
  </section>

  <section class="products" id="products">
    <div class="section-title">
      <h2>Our Coffee Products</h2>
    </div>

    <div class="product-grid">
      <div class="card">
        <img src="arabica.jpg" alt="Arabica Gayo">
        <h3>Arabica Gayo</h3>
        <p>Aceh origin coffee with rich aroma and smooth body.</p>
        <a href="#" class="btn small">View Details</a>
      </div>

      <div class="card">
        <img src="robusta.jpg" alt="Toraja Coffee">
        <h3>Arabica Toraja</h3>
        <p>Premium coffee with earthy flavor and low acidity.</p>
        <a href="#" class="btn small">View Details</a>
      </div>

      <div class="card">
        <img src="robusta 2.jpg" alt="Kintamani Coffee">
        <h3>Arabica Kintamani</h3>
        <p>Fresh citrus notes with sweet aftertaste from Bali.</p>
        <a href="#" class="btn small">View Details</a>
      </div>

      <div class="card">
        <img src="arabica2.jpg" alt="Lampung Coffee">
        <h3>Robusta Lampung</h3>
        <p>Strong flavor and bold aroma for espresso blends.</p>
        <a href="#" class="btn small">View Details</a>
      </div>

      <div class="card">
        <img src="robusta4.jpg" alt="Temanggung Coffee">
        <h3>Robusta Temanggung</h3>
        <p>Unique smoky character with deep robust taste.</p>
        <a href="#" class="btn small">View Details</a>
      </div>

      <div class="card">
        <img src="rubusta5.jpg" alt="Liberica Coffee">
        <h3>Liberica Coffee</h3>
        <p>Rare coffee with fruity notes and exotic aroma.</p>
        <a href="#" class="btn small">View Details</a>
      </div>
    </div>
  </section>

  <section class="why-us">
    <div class="section-title">
      <h2>Why Choose Our Coffee</h2>
    </div>

    <div class="why-grid">
      <div class="why-card">Direct From Farmers</div>
      <div class="why-card">Export Quality Standard</div>
      <div class="why-card">Competitive Price</div>
      <div class="why-card">Consistent Supply</div>
      <div class="why-card">Sustainable Farming</div>
      <div class="why-card">Worldwide Shipping</div>
    </div>
  </section>

  <section class="gallery" id="gallery">
    <div class="section-title">
      <h2>Gallery</h2>
    </div>

    <div class="gallery-grid">
      <img src="g1.jpg" alt="Gallery">
      <img src="g2.jpg" alt="Gallery">
      <img src="g3.jpg" alt="Gallery">
      <img src="g4.jpg" alt="Gallery">
      <img src="g5.jpg" alt="Gallery">
      <img src="g6.jpg" alt="Gallery">
    </div>
  </section>

  <section class="market" id="market">
    <div class="section-title">
      <h2>Our Export Markets</h2>
    </div>

    <div class="market-grid">
      <div class="market-card">United States</div>
      <div class="market-card">Japan</div>
      <div class="market-card">South Korea</div>
      <div class="market-card">Germany</div>
      <div class="market-card">UAE</div>
      <div class="market-card">Australia</div>
    </div>
  </section>

  <section class="testimonial">
    <div class="section-title">
      <h2>Testimonials</h2>
    </div>

    <div class="testimonial-grid">
      <div class="testimonial-card">
        <p>"Excellent quality and reliable supplier."</p>
        <h4>Buyer from Japan</h4>
      </div>

      <div class="testimonial-card">
        <p>"Their coffee beans have great consistency and aroma."</p>
        <h4>Buyer from Germany</h4>
      </div>

      <div class="testimonial-card">
        <p>"Professional service and fast shipping."</p>
        <h4>Buyer from UAE</h4>
      </div>
    </div>
  </section>

  <section class="contact" id="contact">
    <div class="section-title">
      <h2>Contact Us</h2>
    </div>

    <form>
      <input type="text" placeholder="Your Name">
      <input type="email" placeholder="Your Email">
      <textarea placeholder="Your Message"></textarea>
      <button type="submit" class="btn">Send Message</button>
    </form>
  </section>

  <section>
  <div>
      <div class="why-card">Competitive Price</div>
      <div class="why-card">Consistent Supply</div>
      <div class="why-card">Sustainable Farming</div>
      <div class="why-card">Worldwide Shipping</div>
    </div>
  </section>

  <footer>
    <h3>Java Coffee Export</h3>
    <p>Premium Indonesian Coffee Supplier</p>
  </footer>
  

</body>
</html>
